# ── Docker / production ────────────────────────────────────────────────────────
# Copied into the postgres container; also used to compose DATABASE_URL for the
# backend container. Change before deploying.
POSTGRES_PASSWORD=changeme

# Port exposed on the host (default 3000)
PORT=3000

# ── Local development (cargo run, outside Docker) ──────────────────────────────
# Point to your local Postgres instance.
DATABASE_URL=postgres://postgres:changeme@localhost:5432/clue?sslmode=disable
